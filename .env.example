# TTS defaults
TTS_PROVIDER=edge
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%
TTS_VOLUME=+0%
TTS_PITCH=+0Hz

# Generic API-compatible TTS. Only used when TTS_PROVIDER=api.
# TTS_API_BASE_URL=
# TTS_API_KEY=
# TTS_API_MODEL=
# TTS_API_VOICE=
# TTS_API_FORMAT=mp3
# TTS_API_TIMEOUT_SECONDS=60

# --- Data source ---
# Native X MCP (provider = "x_mcp"):
# X_BEARER_TOKEN=

# SuperGrok OAuth (provider = "grok"):
# Do NOT put OAuth tokens here. Run:
#   x2video auth login
# Credentials are stored in ~/.config/x2video/grok_auth.json
